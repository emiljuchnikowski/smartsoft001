{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "es2022",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@smartsoft001/angular": ["packages/shared/angular/src/index.ts"],
      "@smartsoft001/auth-domain": ["packages/auth/domain/src/index.ts"],
      "@smartsoft001/auth-shell-app-services": [
        "packages/auth/shell/app-services/src/index.ts"
      ],
      "@smartsoft001/crud-domain": ["packages/crud/domain/src/index.ts"],
      "@smartsoft001/crud-shell-app-services": [
        "packages/crud/shell/app-services/src/index.ts"
      ],
      "@smartsoft001/crud-shell-dtos": [
        "packages/crud/shell/dtos/src/index.ts"
      ],
      "@smartsoft001/crud-shell-nestjs": [
        "packages/crud/shell/nestjs/src/index.ts"
      ],
      "@smartsoft001/domain-core": ["packages/shared/domain-core/src/index.ts"],
      "@smartsoft001/fb": ["packages/shared/fb/src/index.ts"],
      "@smartsoft001/google": ["packages/shared/google/src/index.ts"],
      "@smartsoft001/models": ["packages/shared/models/src/index.ts"],
      "@smartsoft001/mongo": ["packages/shared/mongo/src/index.ts"],
      "@smartsoft001/nestjs": ["packages/shared/nestjs/src/index.ts"],
      "@smartsoft001/paynow": ["packages/shared/paynow/src/index.ts"],
      "@smartsoft001/paypal": ["packages/shared/paypal/src/index.ts"],
      "@smartsoft001/payu": ["packages/shared/payu/src/index.ts"],
      "@smartsoft001/revolut": ["packages/shared/revolut/src/index.ts"],
      "@smartsoft001/trans-domain": ["packages/trans/domain/src/index.ts"],
      "@smartsoft001/trans-shell-app-services": [
        "packages/trans/shell/app-services/src/index.ts"
      ],
      "@smartsoft001/trans-shell-dtos": [
        "packages/trans/shell/dtos/src/index.ts"
      ],
      "@smartsoft001/trans-shell-nestjs": [
        "packages/trans/shell/nestjs/src/index.ts"
      ],
      "@smartsoft001/users": ["packages/shared/users/src/index.ts"],
      "@smartsoft001/utils": ["packages/shared/utils/src/index.ts"],
      "@angular/core/testing": [
        "node_modules/@angular/core/types/testing.d.ts"
      ],
      "@angular/core/rxjs-interop": [
        "node_modules/@angular/core/types/rxjs-interop.d.ts"
      ],
      "@angular/common/http": ["node_modules/@angular/common/types/http.d.ts"],
      "@angular/common/http/testing": [
        "node_modules/@angular/common/types/http-testing.d.ts"
      ],
      "@angular/platform-browser/testing": [
        "node_modules/@angular/platform-browser/types/testing.d.ts"
      ],
      "@angular/platform-browser-dynamic/testing": [
        "node_modules/@angular/platform-browser-dynamic/types/testing.d.ts"
      ],
      "@angular/router/testing": [
        "node_modules/@angular/router/types/testing.d.ts"
      ],
      "@angular/cdk/*": ["node_modules/@angular/cdk/types/*.d.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
