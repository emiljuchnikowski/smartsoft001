{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(mkdir:*)",
      "Bash(nx:*)",
      "Bash(npx nx:*)",
      "Bash(npx tsc:*)",
      "Bash(pnpm:*)",
      "Bash(npm run format:*)",
      "Bash(npm test:*)",
      "Bash(npm audit:*)",
      "Bash(npm install:*)",
      "Bash(source:*)",
      "Bash(nvm use:*)",
      "Bash(node:*)",
      "Bash(lsof:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)",
      "Bash(sleep:*)",
      "Bash(rm:*)",
      "Bash(test:*)",
      "Bash(for:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh pr list:*)"
    ],
    "deny": [],
    "ask": ["Bash(git commit:*)", "Bash(git push:*)", "Bash(gh pr create:*)"]
  },
  "enabledPlugins": {
    "smart@smartsoft": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
