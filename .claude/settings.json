{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(mkdir:*)",
      "Bash(nx:*)",
      "Bash(npx nx:*)",
      "Bash(npx tsc:*)",
      "Bash(pnpm:*)",
      "Bash(npm run format:*)",
      "Bash(npm test:*)",
      "Bash(npm audit:*)",
      "Bash(npm install:*)",
      "Bash(source:*)",
      "Bash(nvm use:*)",
      "Bash(node:*)",
      "Bash(lsof:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)",
      "Bash(sleep:*)",
      "Bash(rm:*)",
      "Bash(test:*)",
      "Bash(for:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh pr list:*)"
    ],
    "deny": [],
    "ask": ["Bash(git commit:*)", "Bash(git push:*)", "Bash(gh pr create:*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "_description": "Safety gate: blocks destructive bash commands",
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "packages/shared/claude-plugins/src/plugins/smart/hooks/safety_validator.py"
          }
        ]
      },
      {
        "_description": "Block sensitive files with detailed error message",
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); echo \"$FILE\" | grep -qE '(\\.env|secrets|credentials)' && { echo \"BLOCKED: Access denied to sensitive file: $FILE\" >&2; exit 2; } || exit 0"
          }
        ]
      },
      {
        "_description": "Audit trail: logs all PreToolUse events",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "packages/shared/claude-plugins/src/plugins/smart/hooks/audit_logger.py"
          }
        ]
      },
      {
        "_description": "Skill validator: soft enforcement warnings for skill files",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "packages/shared/claude-plugins/src/plugins/smart/hooks/skill_validator.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_description": "Auto-format files after Write/Edit",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format 2>/dev/null || true"
          }
        ]
      },
      {
        "_description": "Audit trail: logs all PostToolUse events",
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "packages/shared/claude-plugins/src/plugins/smart/hooks/audit_logger.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_description": "Audit trail: logs all user prompt submissions",
        "hooks": [
          {
            "type": "command",
            "command": "packages/shared/claude-plugins/src/plugins/smart/hooks/audit_logger.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "smart@smartsoft": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
